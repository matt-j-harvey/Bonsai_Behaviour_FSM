            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:Timestamp" />
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Expression>"C:\\Bonsai_Data\\fsm_log_" + it.Timestamp.ToString("yyyy-MM-dd_HH-mm-ss") + ".csv"</scr:Expression>
            </Expression>
            <Expression xsi:type="rx:BehaviorSubject">
              <Name>FSM_Log_Filename</Name>
