        <Combinator xsi:type="StringProperty">
          <Value>initialising_hardware</Value>
        </Combinator>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:Merge" />
      </Expression>
      <Expression xsi:type="rx:Scan">
        <Name>State_Reducer</Name>
        <Workflow>
          <Nodes>
            <Expression xsi:type="WorkflowInput">
              <Name>Source1</Name>
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Name>Get State and Event</scr:Name>
              <scr:Expression>new(
  it.Accumulation as State,
  it.Value as Event
)</scr:Expression>
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Name>State_Reducer</scr:Name>
              <scr:Expression>it.State == "initialising_hardware" &amp;&amp; it.Event == "hardware_ready" ? "setting_trial_details" :
it.State == "setting_trial_details" &amp;&amp; it.Event == "trial_ready" ? "monitoring_speed" :
it.State == "monitoring_speed" &amp;&amp; it.Event == "running_criterion_met" ? "dispensing_reward" :
it.State == "dispensing_reward" &amp;&amp; it.Event == "reward_dispensed" ? "inter_trial_interval" :
it.State == "inter_trial_interval" &amp;&amp; it.Event == "iti_elapsed" ? "setting_trial_details" :
it.State</scr:Expression>
            </Expression>
            <Expression xsi:type="WorkflowOutput" />
          </Nodes>
          <Edges>
            <Edge From="0" To="1" Label="Source1" />
            <Edge From="1" To="2" Label="Source1" />
            <Edge From="2" To="3" Label="Source1" />
          </Edges>
        </Workflow>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:DistinctUntilChanged" />
